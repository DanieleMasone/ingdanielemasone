    "doc": "jsdoc -c jsdoc.json -d docs",
    "prepare:reports": "node scripts/prepare-published-reports.mjs",
    "build:reports": "npm run coverage && npm run doc && npm run prepare:reports",
    "build:all": "npm run build && npm run build:reports",
