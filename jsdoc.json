{
  "tags": {
    "allowUnknownTags": true
  },
  "source": {
    "include": ["src", "scripts"],
    "includePattern": "\\.(js|jsx|mjs)$",
    "excludePattern": "(node_modules|dist|build|public|coverage|docs|docs-src|\\.test\\.|setupTests\\.js)"
  },
  "opts": {
    "destination": "./docs",
    "recurse": true,
    "readme": "docs-src/source-docs-home.md",
    "tutorials": "docs-src/tutorials",
    "template": "node_modules/docdash",
    "encoding": "utf8"
  },
  "templates": {
    "cleverLinks": true,
    "monospaceLinks": true,
    "default": {
      "outputSourceFiles": true
    }
  }
}
